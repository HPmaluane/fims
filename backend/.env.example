# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fims_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# CORS - frontend URL
CORS_ORIGIN=http://localhost:5173
